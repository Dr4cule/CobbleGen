# CobbleGen example configuration
# Copy this file to .env and adjust the values for your machine.

# Core paths. Relative paths are resolved from the project folder.
FOOTAGE_DIR=footage
MUSIC_DIR=music
STORIES_DIR=stories
OUTPUT_DIR=output
TEMP_DIR=temp
STATE_FILE=pipeline_state.json

# Story intelligence
DISABLE_GEMINI=true
ENABLE_OLLAMA_FALLBACK=true

# Option A: single local Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-super:cloud

# Option B: multiple Ollama hosts with failover. Each entry can pin a model as url|model.
# For a master/slave setup, uncomment and edit this line:
# OLLAMA_HOSTS=http://master:11434|nemotron-3-super:cloud,http://slave:11434|qwen3.6:27b
OLLAMA_REQUEST_TIMEOUT=300

# Optional Gemini fallback; keep disabled unless you provide a key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# TTS backend
# Recommended: nvidia_magpie. Offline/simple fallback: edge_tts.
TTS_BACKEND=nvidia_magpie
TTS_VOICE=en-US-GuyNeural
NVIDIA_API_KEY=replace_me
NVIDIA_RIVA_SERVER=grpc.nvcf.nvidia.com:443
NVIDIA_RIVA_USE_SSL=true
NVIDIA_MAGPIE_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
NVIDIA_TTS_LANGUAGE_CODE=en-US
NVIDIA_TTS_VOICE=Magpie-Multilingual.EN-US.Mia
NVIDIA_DYNAMIC_EMOTION=true
NVIDIA_DEFAULT_EMOTION=neutral
NVIDIA_TTS_SAMPLE_RATE_HZ=22050
NVIDIA_TTS_MAX_CHARS=350
NVIDIA_TTS_MAX_ATTEMPTS=2
NVIDIA_TTS_CHUNK_CROSSFADE_MS=25
NVIDIA_TTS_GRPC_MAX_MESSAGE_MB=64
# Emotion mode: dominant (consistent, default) | dynamic (per-chunk) | off
NVIDIA_EMOTION_MODE=dominant
NVIDIA_TTS_NORMALIZE_CHUNKS=true

# ElevenLabs (optional engine, selectable per reel; free tier ~10k chars/month).
# Premade default voices that work on free tier include George, Brian, Bill.
ELEVENLABS_API_KEY=replace_me
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY=0.8
ELEVENLABS_STYLE=0.45
TTS_AUDIO_QUALITY_GUARD=true
TTS_STATIC_ZCR_THRESHOLD=0.24
TTS_STATIC_RMS_DB_THRESHOLD=-50
TTS_STATIC_MAX_SECONDS=2
TTS_REQUEST_TIMEOUT=900
ENABLE_TTS_FALLBACK=true
TTS_FALLBACK_BACKEND=edge_tts

# Optional remote/local story narration APIs for advanced setups.
VOX_CPM_URL=http://localhost:8001/tts
VOX_CPM_SPEAKER=
VOX_CPM_MAX_CHARS=80
VOX_CPM_PROMPT_WAV=
VOX_CPM_PROMPT_TEXT=
PARLER_TTS_URL=http://localhost:8001/tts
PARLER_SPEAKER_ID=aurora
PARLER_EMOTION=dramatic
PARLER_VOICE_DESCRIPTION=
PARLER_TEMPERATURE=0.45
PARLER_MAX_NEW_TOKENS=2048
PARLER_MIN_NEW_TOKENS=384
PARLER_TOKENS_PER_SECOND=90
PARLER_TOKEN_MARGIN=1.25
PARLER_LOCAL_CHUNKING_ENABLED=true
PARLER_LOCAL_CHUNK_CHARS=160
PARLER_MAX_ATTEMPTS=3
PARLER_CHUNK_CROSSFADE_MS=30

# Subtitle timing
USE_WHISPER_ALIGN=false
WHISPER_MODEL=base
WORDS_PER_CAPTION_GROUP=4
SUBTITLE_MAX_CHARS_PER_LINE=18
SUBTITLE_MAX_LINES=2
SUBTITLE_MARGIN_H=60
SUBTITLE_V_MARGIN=170

# Optional Unsplash scene images. Leave blank/0 to skip image fetching.
UNSPLASH_ACCESS_KEY=
UNSPLASH_MAX_IMAGES=0

# Output tuning
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
OUTPUT_FPS=30
VIDEO_BITRATE=5M
AUDIO_BITRATE=192k
VIDEO_RENDER_PREFER_GPU=true
VIDEO_CODEC=auto
AUDIO_MASTERING_ENABLED=true
BACKGROUND_MUSIC_ENABLED=true
BACKGROUND_MUSIC_FILE=
BACKGROUND_MUSIC_VOLUME=0.13
NARRATION_VOLUME=1.0
MUSIC_FADE_SEC=1.25

# Reel controls
MAX_REEL_DURATION=180
MIN_REEL_DURATION=20
STORY_TARGET_WPM=145
MIN_SCENE_COUNT=3
MAX_SCENE_COUNT=8
SECONDS_PER_SCENE_IMAGE=22
IMAGE_DISPLAY_SEC=3.5
IMAGE_FADE_SEC=0.45
IMAGE_OPACITY=0.88
IMAGE_BLUR_BG=true
SHOW_INTRO_CARD=true
INTRO_DURATION=2.5
INTRO_NARRATION_ENABLED=true
OUTRO_NARRATION_ENABLED=true
OUTRO_TEXT=
MIN_CLIP_GAP=5
INTRO_MAX_CHARS_PER_LINE=24
ENABLE_EXPRESSIVE_NARRATION=true
NARRATION_STYLE_HINT=emotionally engaging storyteller with natural pauses and dramatic beats
SCENE_CAPTION_FONT_SIZE=44
SCENE_CAPTION_MAX_CHARS_PER_LINE=24
